            </ul>`;

            cartContainer.innerHTML = cartHTML;
            formCartPreview.innerHTML = formPreviewHTML;

            // Update badge and prices
            cartBadge.innerText = totalItemsCount;
            cartBadge.classList.remove('hidden');
            cartTotalPrice.innerText = `${totalPrice.toLocaleString('fr-FR')} FCFA`;
        }

