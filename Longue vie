    <script>
        // Shopping Cart State Management
        let cart = [];

        function addToCart(name, price, icon) {
            const existingItem = cart.find(item => item.name === name);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({ name, price, icon, quantity: 1 });
            }
            updateCartUI();
            showToast(`"${name}" ajouté au panier !`, icon);
        }

        function updateQuantity(name, amount) {
            const item = cart.find(item => item.name === name);
            if (!item) return;
            
            item.quantity += amount;
            if (item.quantity <= 0) {
                cart = cart.filter(i => i.name !== name);
            }
            updateCartUI();
        }

        function removeFromCart(name) {
            cart = cart.filter(item => item.name !== name);
            updateCartUI();
            showToast("Article supprimé de votre sélection", "🗑️");
        }

        function updateCartUI() {
            const cartContainer = document.getElementById('cart-items-container');
            const formCartPreview = document.getElementById('form-cart-preview');
            const cartBadge = document.getElementById('cart-badge');
            const cartTotalPrice = document.getElementById('cart-total-price');

            // Total calculations
            let totalItemsCount = 0;
            let totalPrice = 0;

            if (cart.length === 0) {
                cartContainer.innerHTML = `<p class="text-stone-500 text-center py-8">Votre panier de vitamines est actuellement vide.</p>`;
                formCartPreview.innerHTML = `<p class="text-stone-500 text-sm text-center py-4">Votre panier est vide. Veuillez ajouter des fruits dans le catalogue ci-dessus.</p>`;
                cartBadge.classList.add('hidden');
                cartTotalPrice.innerText = `0 FCFA`;
                return;
            }

            // Fill sidebar cart
            let cartHTML = '';
            let formPreviewHTML = '<ul class="space-y-2">';
            
            cart.forEach(item => {
                totalItemsCount += item.quantity;
                totalPrice += (item.price * item.quantity);

                cartHTML += `
                    <div class="flex items-center justify-between p-3.5 bg-stone-50 rounded-2xl border border-stone-100">
                        <div class="flex items-center gap-3">
                            <span class="text-3xl">${item.icon}</span>
                            <div>
                                <h4 class="font-bold text-stone-900 text-sm leading-tight">${item.name}</h4>
                                <span class="text-xs text-stone-500">${item.price} FCFA / u</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button onclick="updateQuantity('${item.name}', -1)" class="w-8 h-8 rounded-full bg-white border border-stone-200 flex items-center justify-center font-bold text-stone-600 hover:bg-stone-100 transition-colors">-</button>
                            <span class="text-sm font-bold w-6 text-center">${item.quantity}</span>
                            <button onclick="updateQuantity('${item.name}', 1)" class="w-8 h-8 rounded-full bg-white border border-stone-200 flex items-center justify-center font-bold text-stone-600 hover:bg-stone-100 transition-colors">+</button>
                            <button onclick="removeFromCart('${item.name}')" class="text-red-500 ml-2 hover:text-red-700" title="Supprimer">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </div>
                `;

                formPreviewHTML += `
                    <li class="flex justify-between items-center text-sm py-1 border-b border-stone-200 last:border-0">
                        <span class="font-medium text-stone-800">${item.icon} ${item.name} (x${item.quantity})</span>
                        <span class="font-bold text-stone-900">${item.price * item.quantity} FCFA</span>
                    </li>
                `;
            });

            formPreviewHTML += `
                <li class="flex justify-between items-center text-sm pt-3 font-extrabold text-stone-950 border-t border-stone-300">
                    <span>Total Sélection</span>
                    <span>${totalPrice} FCFA</span>
