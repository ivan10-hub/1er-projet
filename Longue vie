            cart.forEach(item => {
                itemsText += `- ${item.icon} ${item.name} (Quantité: ${item.quantity}) -> ${item.price * item.quantity} FCFA\n`;
                totalAmount += item.price * item.quantity;
            });

            const rawMessage = `Bonjour Longue Vie Contact ! 🌿\nJe souhaite commander une cure de fruits frais découpés :\n\n👤 *Client :* ${name}\n📞 *Téléphone :* ${phone}\n📍 *Livraison :* ${address}\n\n🛒 *Ma sélection :*\n${itemsText}\n💰 *Montant Total :* *${totalAmount} FCFA*\n\n📝 *Notes/Préférences :* ${notes ? notes : 'Aucune'}\n\nMerci de me confirmer la prise en charge de ma livraison !`;
            
            const encodedMessage = encodeURIComponent(rawMessage);
            const whatsappURL = `https://wa.me/2250101878025?text=${encodedMessage}`;

            // Open WhatsApp in a new window/tab
            window.open(whatsappURL, '_blank');
        }
    </script>
